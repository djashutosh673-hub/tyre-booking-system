<%- include('partials/header') %>
<div class="container" style="padding: 2rem 0;">
  <h2>Your Cart</h2>
  <% if(!cart || cart.length === 0) { %>
    <p>Your cart is empty. <a href="/shop">Shop now</a></p>
  <% } else { %>
    <table class="cart-table">
      <thead>
        <tr><th>Product</th><th>Price</th><th>Quantity</th><th>Subtotal</th><th></th></tr>
      </thead>
      <tbody>
        <% cart.forEach(item => { %>
        <tr>
          <td><%= item.name || item.brand + ' ' + item.model %> <%= item.size ? '('+item.size+')' : '' %></td>
          <td>₹<%= item.price %></td>
          <td>
            <form action="/cart/update" method="POST" style="display:inline;">
              <input type="hidden" name="id" value="<%= item.id %>">
              <input type="number" name="quantity" value="<%= item.quantity %>" min="1" style="width:70px;">
              <button type="submit">Update</button>
            </form>
          </td>
          <td>₹<%= item.price * item.quantity %></td>
          <td>
            <form action="/cart/remove/<%= item.id %>" method="POST">
              <button type="submit" style="background:#dc3545;">Remove</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr><td colspan="3"><strong>Total</strong></td><td colspan="2"><strong>₹<%= total %></strong></td></tr>
      </tfoot>
    </table>
    <a href="/checkout" class="btn-primary" style="display:inline-block; margin-top:1rem;">Proceed to Checkout</a>
  <% } %>
</div>
<%- include('partials/footer') %>