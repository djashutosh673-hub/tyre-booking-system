<!DOCTYPE html>
<html>
<head>
<title>Book Service</title>
<style>
body{font-family:sans-serif;background:#f5f7fa;padding:40px;}
form{background:white;padding:20px;border-radius:8px;max-width:400px;margin:auto;}
input,select,button{width:100%;margin:10px 0;padding:10px;}
button{background:#2c3e50;color:white;border:none;}
</style>
</head>
<body>

<h2 style="text-align:center;">🚗 Book Tyre Service</h2>

<form action="/book" method="POST">
<input type="text" name="name" placeholder="Your Name" required>
<input type="text" name="vehicle" placeholder="Vehicle" required>

<select name="service">
<option value="repair">Repair</option>
<option value="replacement">Replacement</option>
</select>

<button type="submit">Book Now</button>
</form>

</body>
</html>