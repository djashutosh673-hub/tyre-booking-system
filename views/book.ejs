<%- include('partials/header') %>

<div class="form-container">
  <div class="form-box">

    <h2>Book Tyre Service</h2>

    <form action="/booking/book" method="POST">

      <div class="form-group">
        <input type="text" name="name" required>
        <label>Your Name</label>
      </div>

      <div class="form-group">
        <input type="text" name="vehicleModel" required>
        <label>Vehicle Model</label>
      </div>

      <div class="form-group">
        <select name="repairType" required>
          <option value="" disabled selected></option>
          <option>Puncture Repair</option>
          <option>Tyre Replacement</option>
          <option>Wheel Alignment</option>
        </select>
        <label>Repair Type</label>
      </div>

      <div class="form-group">
        <input type="text" name="phone" required>
        <label>Phone</label>
      </div>

      <div class="form-group">
        <textarea name="address" required></textarea>
        <label>Address</label>
      </div>

      <button type="button" class="location-btn">
        📍 Get My Location
      </button>

      <button type="submit" class="submit-btn">
        Book Now
      </button>

    </form>

  </div>
</div>

<%- include('partials/footer') %>