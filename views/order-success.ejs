<%- include('partials/header') %>

<div class="success-container">
  <div class="success-card">
    <i class="fas fa-check-circle success-icon"></i>
    <h1>Order Placed Successfully!</h1>
    <p><%= message %></p>
    <p>Your Order ID: <strong><%= orderId %></strong></p>
    <p>We'll deliver your tyres soon.</p>

    <div class="action-buttons">
      <a href="/track-order" class="btn primary">Track Your Order</a>
      <a href="/shop" class="btn secondary">Continue Shopping</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<style>
  .success-container {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f4f6f9;
    padding: 2rem;
  }
  .success-card {
    background: white;
    border-radius: 28px;
    padding: 2.5rem;
    text-align: center;
    max-width: 500px;
    width: 100%;
    box-shadow: 0 12px 28px rgba(0,0,0,0.08);
  }
  .success-icon {
    font-size: 4rem;
    color: #10b981;
    margin-bottom: 1rem;
  }
  .success-card h1 {
    color: #1e3c72;
    margin-bottom: 1rem;
  }
  .success-card p {
    color: #4a5568;
    margin: 0.5rem 0;
  }
  .action-buttons {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  .action-buttons .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
  }
  .action-buttons .primary {
    background: #1e3c72;
    color: white;
  }
  .action-buttons .secondary {
    background: #e2e8f0;
    color: #1e293b;
  }
  .action-buttons .primary:hover {
    background: #2a5298;
  }
  .action-buttons .secondary:hover {
    background: #cbd5e1;
  }
</style>