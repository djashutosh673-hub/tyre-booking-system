<%- include('../partials/header') %>

<div class="dashboard-wrapper">
  <div class="dashboard-header">
    <h2><i class="fas fa-tools"></i> Mechanic Dashboard</h2>
    <a href="/mechanic/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>

  <!-- Stats (optional, but you can compute from both collections) -->
  <div class="stats-grid">
    <div class="stat-card">
      <i class="fas fa-clock"></i>
      <h3><%= serviceBookings.filter(b => b.status === 'Pending').length + deliveryOrders.filter(o => o.deliveryStatus === 'Pending').length %></h3>
      <p>Pending Requests</p>
    </div>
    <div class="stat-card">
      <i class="fas fa-user-check"></i>
      <h3><%= serviceBookings.filter(b => b.status === 'Assigned' && b.mechanicId == user.id).length + deliveryOrders.filter(o => o.deliveryStatus === 'Assigned' && o.assignedMechanicId == user.id).length %></h3>
      <p>Your Active Jobs</p>
    </div>
    <div class="stat-card">
      <i class="fas fa-check-circle"></i>
      <h3><%= serviceBookings.filter(b => b.status === 'Completed').length + deliveryOrders.filter(o => o.deliveryStatus === 'Completed').length %></h3>
      <p>Completed</p>
    </div>
  </div>

  <!-- Service Bookings Table -->
  <div class="section-title">
    <i class="fas fa-wrench"></i> Service Requests
  </div>
  <% if (serviceBookings.length === 0) { %>
    <div class="empty-state">No service requests.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="dashboard-table">
        <thead>
          <tr><th>ID</th><th>Name</th><th>Vehicle</th><th>Repair</th><th>Phone</th><th>Location</th><th>Status</th><th>Action</th> </tr>
        </thead>
        <tbody>
          <% serviceBookings.forEach(booking => { %>
            <tr>
              <td data-label="ID"><%= booking.id %></td>
              <td data-label="Name"><%= booking.name %></td>
              <td data-label="Vehicle"><%= booking.vehicle %></td>
              <td data-label="Repair"><%= booking.repair %></td>
              <td data-label="Phone"><%= booking.phone %></td>
              <td data-label="Location">
                <% if(booking.latitude && booking.longitude) { %>
                  <a href="https://maps.google.com/?q=<%= booking.latitude %>,<%= booking.longitude %>" target="_blank"><i class="fas fa-map-marker-alt"></i> View Map</a>
                <% } else { %>No location<% } %>
              </td>
              <td data-label="Status"><span class="status-badge status-<%= booking.status.toLowerCase() %>"><%= booking.status %></span></td>
              <td data-label="Action">
                <% if(booking.status === 'Pending') { %>
                  <form action="/mechanic/assign/<%= booking.id %>" method="POST"><button type="submit" class="action-btn assign-btn">Accept</button></form>
                <% } else if(booking.status === 'Assigned' && booking.mechanicId == user.id) { %>
                  <form action="/mechanic/complete/<%= booking.id %>" method="POST"><button type="submit" class="action-btn complete-btn">Complete</button></form>
                <% } else if(booking.status === 'Completed') { %>
                  <span class="done-badge">Done</span>
                <% } else { %>
                  <span class="assigned-else">Assigned to another</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <!-- Delivery Orders Table -->
  <div class="section-title">
    <i class="fas fa-truck"></i> Delivery Orders (Tyre Purchases)
  </div>
  <% if (deliveryOrders.length === 0) { %>
    <div class="empty-state">No delivery orders.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="dashboard-table">
        <thead>
          <tr><th>Order ID</th><th>Customer</th><th>Phone</th><th>Address</th><th>Items</th><th>Total</th><th>Status</th><th>Action</th> </tr>
        </thead>
        <tbody>
          <% deliveryOrders.forEach(order => { %>
            <tr>
              <td data-label="Order ID"><%= order.id %></td>
              <td data-label="Customer"><%= order.customerName %></td>
              <td data-label="Phone"><%= order.customerPhone %></td>
              <td data-label="Address"><%= order.deliveryAddress %></td>
              <td data-label="Items"><%= order.items.map(i => `${i.name} (x${i.quantity})`).join(', ') %></td>
              <td data-label="Total">₹<%= order.total %></td>
              <td data-label="Status"><span class="status-badge status-<%= order.deliveryStatus.toLowerCase() %>"><%= order.deliveryStatus %></span></td>
              <td data-label="Action">
                <% if(order.deliveryStatus === 'Pending') { %>
                  <form action="/mechanic/assign-delivery/<%= order.id %>" method="POST"><button type="submit" class="action-btn assign-btn">Accept</button></form>
                <% } else if(order.deliveryStatus === 'Assigned' && order.assignedMechanicId == user.id) { %>
                  <form action="/mechanic/complete-delivery/<%= order.id %>" method="POST"><button type="submit" class="action-btn complete-btn">Complete</button></form>
                <% } else if(order.deliveryStatus === 'Completed') { %>
                  <span class="done-badge">Delivered</span>
                <% } else { %>
                  <span class="assigned-else">Assigned to another</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>

<style>
  /* same styles as before, plus section titles */
  .section-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: #1e3c72;
    margin: 1.5rem 0 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .dashboard-wrapper {
    max-width: 1400px;
    margin: 2rem auto;
    padding: 0 1.5rem;
  }
  /* add other styles from previous version */
</style>