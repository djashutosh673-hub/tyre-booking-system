<%- include('partials/header') %>
    <!-- Hero Section -->
    <section class="hero">
        <div class="container hero-content">
            <h1>Drive with Confidence</h1>
            <p>Premium tyres from world-leading brands + doorstep service. Performance, safety, and style.</p>
            <div class="hero-buttons">
                <a href="/shop" class="btn btn-primary"><i class="fas fa-shopping-cart"></i> Buy Tyres Now</a>
                <a href="/booking/book" class="btn btn-outline"><i class="fas fa-truck"></i> Book Home Service</a>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section class="features">
        <div class="container">
            <div class="features-grid">
                <div class="feature-card"><i class="fas fa-tachometer-alt"></i><h3>High Performance</h3><p>Engineered for maximum grip and durability</p></div>
                <div class="feature-card"><i class="fas fa-road"></i><h3>All Terrain</h3><p>From city roads to off-road adventures</p></div>
                <div class="feature-card"><i class="fas fa-clock"></i><h3>24/7 Support</h3><p>Emergency roadside assistance</p></div>
                <div class="feature-card"><i class="fas fa-tools"></i><h3>Expert Installation</h3><p>Certified mechanics at your doorstep</p></div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-service">
        <div class="container cta-content">
            <h2>Flat Tyre? We come to you!</h2>
            <p>Book a mobile mechanic for tyre repair, replacement, or rotation. Available 24x7.</p>
            <a href="/booking/book" class="btn btn-light">Book Now</a>
        </div>
    </section>
<%- include('partials/footer') %>