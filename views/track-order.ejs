<%- include('partials/header') %>

<div class="track-order-container">
  <div class="track-order-card">
    <div class="track-header">
      <i class="fas fa-truck"></i>
      <h2>Track Your Order</h2>
      <p>Enter your Order ID or phone number to get the latest status</p>
    </div>

    <form action="/track-order" method="POST" class="track-form">
      <div class="input-group">
        <input type="text" name="identifier" placeholder="Order ID or Phone Number" value="<%= identifier %>" required>
        <button type="submit"><i class="fas fa-search"></i> Track</button>
      </div>
    </form>

    <% if (order) { %>
      <div class="order-details">
        <div class="order-header">
          <h3>Order #<%= order.id %></h3>
          <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
        </div>

        <div class="info-grid">
          <div class="info-item">
            <i class="fas fa-calendar-alt"></i>
            <div>
              <strong>Date</strong>
              <span><%= new Date(order.createdAt).toLocaleString() %></span>
            </div>
          </div>
          <div class="info-item">
            <i class="fas fa-rupee-sign"></i>
            <div>
              <strong>Total</strong>
              <span>₹<%= order.total %></span>
            </div>
          </div>
          <div class="info-item">
            <i class="fas fa-credit-card"></i>
            <div>
              <strong>Payment</strong>
              <span><%= order.paymentMethod %></span>
            </div>
          </div>
          <div class="info-item">
            <i class="fas fa-map-marker-alt"></i>
            <div>
              <strong>Delivery Address</strong>
              <span><%= order.deliveryAddress %></span>
            </div>
          </div>
        </div>

        <h4>Items Ordered</h4>
        <div class="items-table">
          <table>
            <thead>
              <tr>
                <th>Product</th>
                <th>Qty</th>
                <th>Price</th>
                <th>Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(item => { %>
                <tr>
                  <td><%= item.name %></td>
                  <td><%= item.quantity %></td>
                  <td>₹<%= item.price %></td>
                  <td>₹<%= item.price * item.quantity %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <% if (order.latitude && order.longitude) { %>
          <div class="map-link">
            <a href="https://maps.google.com/?q=<%= order.latitude %>,<%= order.longitude %>" target="_blank">
              <i class="fas fa-map"></i> View Delivery Location on Map
            </a>
          </div>
        <% } %>

        <div class="status-timeline">
          <div class="timeline-step <%= order.status === 'Confirmed' ? 'active' : (order.status === 'Shipped' ? 'done' : '') %>">
            <div class="icon"><i class="fas fa-check-circle"></i></div>
            <div class="label">Confirmed</div>
          </div>
          <div class="timeline-step <%= order.status === 'Shipped' ? 'active' : (order.status === 'Delivered' ? 'done' : '') %>">
            <div class="icon"><i class="fas fa-shipping-fast"></i></div>
            <div class="label">Shipped</div>
          </div>
          <div class="timeline-step <%= order.status === 'Delivered' ? 'active' : '' %>">
            <div class="icon"><i class="fas fa-home"></i></div>
            <div class="label">Delivered</div>
          </div>
        </div>
      </div>
    <% } else if (identifier) { %>
      <div class="error-message">
        <i class="fas fa-exclamation-circle"></i>
        <p>No order found with that ID or phone number. Please check and try again.</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

<style>
  .track-order-container {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f7fa 0%, #e9eef3 100%);
    padding: 2rem;
  }
  .track-order-card {
    background: white;
    border-radius: 32px;
    box-shadow: 0 20px 35px -10px rgba(0,0,0,0.1);
    width: 100%;
    max-width: 800px;
    overflow: hidden;
    transition: transform 0.2s;
  }
  .track-header {
    background: linear-gradient(90deg, #1e3c72, #2a5298);
    color: white;
    text-align: center;
    padding: 2rem 1.5rem;
  }
  .track-header i {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  .track-header h2 {
    margin: 0;
    font-size: 1.8rem;
  }
  .track-header p {
    margin: 0.5rem 0 0;
    opacity: 0.9;
  }
  .track-form {
    padding: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
  }
  .input-group {
    display: flex;
    gap: 0.75rem;
  }
  .input-group input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid #cbd5e1;
    border-radius: 40px;
    font-size: 1rem;
    transition: 0.2s;
  }
  .input-group input:focus {
    border-color: #2a5298;
    outline: none;
    box-shadow: 0 0 0 3px rgba(42,82,152,0.2);
  }
  .input-group button {
    background: #2a5298;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 40px;
    color: white;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: 0.2s;
  }
  .input-group button:hover {
    background: #1e3c72;
    transform: translateY(-1px);
  }
  .order-details {
    padding: 1.5rem;
  }
  .order-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .order-header h3 {
    margin: 0;
    font-size: 1.3rem;
    color: #1e293b;
  }
  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .status-Confirmed {
    background: #dbeafe;
    color: #1e40af;
  }
  .status-Shipped {
    background: #fef3c7;
    color: #b45309;
  }
  .status-Delivered {
    background: #d1fae5;
    color: #065f46;
  }
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .info-item i {
    color: #2a5298;
    font-size: 1.1rem;
    margin-top: 0.2rem;
  }
  .info-item div {
    display: flex;
    flex-direction: column;
  }
  .info-item strong {
    font-size: 0.7rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .info-item span {
    font-weight: 500;
    color: #1e293b;
  }
  .items-table {
    overflow-x: auto;
    margin: 1rem 0;
  }
  .items-table table {
    width: 100%;
    border-collapse: collapse;
  }
  .items-table th, .items-table td {
    padding: 0.75rem;
    text-align: left;
    border-bottom: 1px solid #e2e8f0;
  }
  .items-table th {
    background: #f8fafc;
    font-weight: 600;
  }
  .map-link {
    text-align: center;
    margin: 1rem 0;
  }
  .map-link a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #2a5298;
    text-decoration: none;
    font-weight: 500;
  }
  .map-link a:hover {
    text-decoration: underline;
  }
  .status-timeline {
    display: flex;
    justify-content: space-between;
    margin-top: 2rem;
    position: relative;
  }
  .status-timeline::before {
    content: '';
    position: absolute;
    top: 1.2rem;
    left: 0;
    right: 0;
    height: 2px;
    background: #e2e8f0;
    z-index: 0;
  }
  .timeline-step {
    text-align: center;
    flex: 1;
    position: relative;
    z-index: 1;
  }
  .timeline-step .icon {
    background: white;
    width: 2.5rem;
    height: 2.5rem;
    line-height: 2.5rem;
    border-radius: 50%;
    border: 2px solid #e2e8f0;
    margin: 0 auto 0.5rem;
    font-size: 1rem;
    color: #94a3b8;
  }
  .timeline-step.done .icon {
    border-color: #10b981;
    background: #d1fae5;
    color: #10b981;
  }
  .timeline-step.active .icon {
    border-color: #2a5298;
    background: #2a5298;
    color: white;
  }
  .timeline-step .label {
    font-size: 0.75rem;
    font-weight: 500;
    color: #475569;
  }
  .timeline-step.done .label,
  .timeline-step.active .label {
    color: #1e293b;
    font-weight: 600;
  }
  .error-message {
    text-align: center;
    padding: 2rem;
    color: #dc2626;
  }
  .error-message i {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  @media (max-width: 600px) {
    .track-order-container {
      padding: 1rem;
    }
    .info-grid {
      grid-template-columns: 1fr;
    }
    .input-group {
      flex-direction: column;
    }
    .input-group button {
      justify-content: center;
    }
  }
</style>