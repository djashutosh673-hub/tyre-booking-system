<%- include('partials/header') %>

<div class="shop-wrapper">

  <h1 class="shop-title">Explore Tyres</h1>

  <% if (vehicle) { %>
    <h2 class="selected-vehicle">
      Showing tyres for <%= vehicle %>
    </h2>
  <% } %>

  <!-- SEARCH -->
  <div class="search-container">
    <input type="text" id="vehicleSearch" placeholder="Search vehicle...">
    <div id="suggestions"></div>
  </div>

  <!-- GRID -->
  <div class="tyre-grid">
    <% tyres.forEach(tyre => { %>
      <div class="tyre-card">

        <div class="badge">Best Seller</div>

        <div class="tyre-image-box">
          <img src="/images/tyre.png" alt="tyre">
        </div>

        <div class="tyre-info">
          <h3><%= tyre.name || "Premium Tyre" %></h3>

          <p class="size"><%= tyre.size %></p>
          <p class="category"><%= tyre.category || "All Season" %></p>

          <div class="rating">
            ⭐⭐⭐⭐☆ <span>(120)</span>
          </div>

          <div class="bottom-section">
            <div>
              <span class="price">₹<%= tyre.price %></span>
              <span class="old-price">₹<%= tyre.price + 1500 %></span>
            </div>

            <button>Add</button>
          </div>
        </div>

      </div>
    <% }) %>
  </div>

</div>

<script src="/js/shop.js"></script>

<%- include('partials/footer') %>