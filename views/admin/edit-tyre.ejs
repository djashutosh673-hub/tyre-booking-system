<%- include('../partials/header') %>

<div class="form-container">
  <div class="form-box">
    <h2>Edit Tyre</h2>
    <form action="/admin/tyres/edit/<%= tyre.id %>" method="POST">
      <div class="form-group">
        <input type="text" name="brand" value="<%= tyre.brand %>" required>
        <label>Brand</label>
      </div>
      <div class="form-group">
        <input type="text" name="model" value="<%= tyre.model %>" required>
        <label>Model</label>
      </div>
      <div class="form-group">
        <input type="text" name="size" value="<%= tyre.size %>" required>
        <label>Size (e.g., 205/55R16)</label>
      </div>
      <div class="form-group">
        <input type="number" name="price" value="<%= tyre.price %>" required>
        <label>Price (₹)</label>
      </div>
      <div class="form-group">
        <input type="text" name="type" value="<%= tyre.type %>" required>
        <label>Type (e.g., All-Season, Performance)</label>
      </div>
      <div class="form-group">
        <input type="number" name="stock" value="<%= tyre.stock %>" required>
        <label>Stock Quantity</label>
      </div>
      <button type="submit" class="submit-btn">Update Tyre</button>
    </form>
    <a href="/admin/dashboard" class="back-link">← Back to Dashboard</a>
  </div>
</div>

<%- include('../partials/footer') %>

<style>
  .back-link {
    display: block;
    text-align: center;
    margin-top: 1rem;
    color: white;
    text-decoration: none;
  }
  .back-link:hover {
    text-decoration: underline;
  }
</style>